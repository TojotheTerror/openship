# Openship API — SaaS development example.
# Copy to .env.saas for SaaS-mode development. Do not commit real secrets.
#
# SINGLE knob — OPENSHIP_TARGET — picks the runtime-target row. The
# table at packages/core/src/runtime-config.ts is the source of URLs.
# Two valid values:
#   OPENSHIP_TARGET=local        → self-hosted (default if unset)
#   OPENSHIP_TARGET=cloud-saas   → the SaaS, on api.openship.io OR a
#                                  tunneled localhost binding
# No NODE_ENV magic, no CLOUD_MODE-based URL inference. Period.

NODE_ENV=development

OPENSHIP_TARGET=cloud-saas
CLOUD_MODE=true
DEPLOY_MODE=cloud

DATABASE_URL=

BETTER_AUTH_SECRET=change-me-in-production

# Required for cloud deployments.
OBLIEN_CLIENT_ID=
OBLIEN_CLIENT_SECRET=

# Required for GitHub App mode.
GITHUB_APP_ID=
GITHUB_APP_SLUG=openship-io
GITHUB_PRIVATE_KEY_BASE64=
GITHUB_WEBHOOK_SECRET=

SYSTEM_DEBUG_LOGS=false
